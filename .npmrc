# Auto-approve native package builds (sharp for Payload image processing, esbuild for tsx).
auto-install-peers=true
strict-peer-dependencies=false

# Payload 3 sub-exports (payload/shared, payload/i18n, etc.) need to be reachable
# from @payloadcms/next at runtime; pnpm's strict node_modules layout hides them
# without a public hoist.
public-hoist-pattern[]=payload
public-hoist-pattern[]=@payloadcms/*
public-hoist-pattern[]=sharp
