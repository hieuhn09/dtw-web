{
  "name": "dtw-web",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "vercel-build": "node scripts/migrate-prod.mjs && turbo run build",
    "migrate:prod": "node scripts/migrate-prod.mjs",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean && rm -rf node_modules",
    "db:generate": "pnpm --filter @dtw/db db:generate",
    "db:migrate": "pnpm --filter @dtw/db db:migrate",
    "db:push": "pnpm --filter @dtw/db db:push",
    "db:studio": "pnpm --filter @dtw/db db:studio",
    "db:seed": "pnpm --filter @dtw/db db:seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
